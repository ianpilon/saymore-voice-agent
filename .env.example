# ── Server ───────────────────────────────────────────────
PORT=3000

# ── OpenAI (REQUIRED) ────────────────────────────────────
# Used server-side only to extract nuggets after each call.
# NEVER put this in the browser. Get one at https://platform.openai.com
OPENAI_API_KEY=sk-replace-me

# ── Optional overrides ───────────────────────────────────
# Model that mines the transcript into nuggets (default: gpt-4o)
# EXTRACTOR_MODEL=gpt-4o

# Model that runs the live interviewer (default: gpt-4o)
# INTERVIEWER_MODEL=gpt-4o
