# Copy this to .env and fill in your keys. (.env is gitignored.)
# See README for details.

PORT=3000

# ── GLM (your LLM) — used by the server to mine nuggets ──────────
GLM_API_KEY=your-glm-key
# OpenAI-compatible base URL for your GLM provider:
#   Zhipu direct : https://open.bigmodel.cn/api/paas/v4/
#   OpenRouter   : https://openrouter.ai/api/v1
#   SiliconFlow  : https://api.siliconflow.cn/v1
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# Exact model string your provider expects for GLM 5.2:
GLM_MODEL=glm-5.2

# ── Live interviewer model (runs INSIDE Vapi) ───────────────────
# Vapi must support the provider. Defaults kept inert.
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL=gpt-4o
